# Copy this file to config/env.local when the package already includes
# playwright-browsers/<os>/chromium-* and runtime browser downloads must be disabled.
CHATCHAT_INTERNAL_USERNAME=chatchat_mcp_internal
CHATCHAT_INTERNAL_ENCRYPTED_SECRET=
CHATCHAT_INTERNAL_SECRET=chatchat_internal_default_secret
CHATCHAT_INTERNAL_CRYPTO_KEY=
CHATCHAT_INTERNAL_CRYPTO_KEY_FILE=
CHATCHAT_MCP_MYSQL_ENCRYPTED_PASSWORD=
CHATCHAT_OPENSEARCH_ENCRYPTED_PASSWORD=
PLAYWRIGHT_BROWSERS_PATH=playwright-browsers
CHAT_WEB_SEARCH_BROWSER_SKIP_DOWNLOAD=true
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
