spring:
  application:
    name: chatchat-mcp-server
  datasource:
    type: com.zaxxer.hikari.HikariDataSource
    url: jdbc:h2:file:./data/h2/chatchat-mcp-server;MODE=MySQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE;DB_CLOSE_DELAY=-1
    driver-class-name: org.h2.Driver
    username: sa
    password: 
    hikari:
      pool-name: ChatChatMcpHikariPool
      maximum-pool-size: 20
      minimum-idle: 2
      connection-timeout: 30000
      idle-timeout: 300000
      max-lifetime: 1200000
      auto-commit: true
      transaction-isolation: TRANSACTION_READ_COMMITTED
  h2:
    console:
      enabled: false
      path: /h2-console
      settings:
        web-allow-others: false
  jpa:
    hibernate:
      ddl-auto: update
    database-platform: org.hibernate.dialect.H2Dialect
    show-sql: false
    properties:
      hibernate:
        format_sql: false

server:
  port: 8090
  servlet:
    context-path: /
    encoding:
      charset: UTF-8
      enabled: true
      force: true
  shutdown: graceful

chatchat:
  internal-credential:
    enabled: true
    username: chatchat_mcp_internal
    # Use com.chatchat.common.security.InternalSecretTool to generate ENC(...).
    encrypted-secret:
    secret: chatchat_internal_default_secret
    crypto-key: ${CHATCHAT_INTERNAL_CRYPTO_KEY:}
    crypto-key-file: ${CHATCHAT_INTERNAL_CRYPTO_KEY_FILE:}
  mcp:
    news-runtime:
      base-url: ${CHATCHAT_NEWS_RUNTIME_URL:http://localhost:8091}
      timeout-millis: ${CHATCHAT_NEWS_RUNTIME_TIMEOUT_MILLIS:30000}
    capabilities:
      news:
        enabled: ${CHATCHAT_NEWS_CAPABILITY_ENABLED:true}
        tools:
          web_search: { enabled: true, agent-callable: true, timeout: 30s }
          news_search: { enabled: true, agent-callable: true, timeout: 30s }
          news_latest: { enabled: true, agent-callable: true, timeout: 20s }
          news_source_status: { enabled: true, agent-callable: false, timeout: 10s }
    admin:
      username: admin
      password: admin123
      encrypted-password:
      token-ttl-minutes: 480
    security:
      require-mcp-token: true
      encrypted-invocation-token:
      invocation-token:
    authorization:
      enabled: false
      api-base-url: http://localhost:8080
      snapshot-path: /api/v1/enterprise/mcp-auth/snapshot
      refresh-interval-ms: 60000
      stale-ttl-seconds: 3600
      fail-open: true
      require-tenant-context: true
      auth:
        enabled: true
        login-path: /api/v1/enterprise/auth/login
        username: chatchat_mcp_internal
        encrypted-password:
        password:
        bearer-token: 
    command-templates:
      # Agent OS default: do not seed scenario-specific execution templates.
      seed-defaults-enabled: false
    sql-templates:
      # Seed built-in read-only database maintenance templates.
      seed-defaults-enabled: true
    lucene:
      # MCP assets/templates/SQL metadata search master switch.
      enabled: true
      # Search engine:
      # - lucene: default local disk index for quick development/deployment.
      # - opensearch: shared remote OpenSearch index for multi-instance deployment.
      # Startup scripts can override this with --search-engine=opensearch.
      engine: lucene
      # Local index directory when engine=lucene.
      index-dir: ./data/lucene/mcp
      max-results: 50
      # Effective only when engine=opensearch. MCP creates separate indexes by asset/template type.
      open-search:
        # Set false to disable OpenSearch even if engine=opensearch.
        enabled: true
        # OpenSearch HTTPS endpoint.
        url: https://localhost:9200
        username: admin
        password: ${CHATCHAT_OPENSEARCH_ENCRYPTED_PASSWORD:${CHATCHAT_OPENSEARCH_PASSWORD:}}
        # Use true for self-signed test clusters, equivalent to curl -k.
        insecure-ssl: true
        # MCP index prefix, for example chatchat_mcp_assets-sql-datasource.
        index-prefix: chatchat_mcp_
        request-timeout-ms: 30000
        search-concurrency:
          enabled: ${CHATCHAT_MCP_SEARCH_CONCURRENCY_ENABLED:true}
          request-timeout-ms: ${CHATCHAT_MCP_SEARCH_REQUEST_TIMEOUT_MS:8000}
          retry-429-attempts: ${CHATCHAT_MCP_SEARCH_RETRY_429_ATTEMPTS:1}
          retry-backoff-min-ms: 100
          retry-backoff-max-ms: 300
          lexical:
            max-running: ${CHATCHAT_MCP_SEARCH_LEXICAL_MAX_RUNNING:12}
            queue-capacity: 30
            queue-timeout-ms: 1500
          vector:
            max-running: ${CHATCHAT_MCP_SEARCH_VECTOR_MAX_RUNNING:4}
            queue-capacity: 10
            queue-timeout-ms: 500
        embedding:
          request-timeout-ms: ${CHATCHAT_EMBEDDING_REQUEST_TIMEOUT_MS:300000}
          # Optional semantic retrieval for MCP assets/templates. Effective only when engine=opensearch.
          # Existing MCP indexes must be deleted and rebuilt once after enabling KNN vectors.
          enabled: true
          endpoint: https://llm-7upawl16up8649rh.cn-beijing.maas.aliyuncs.com/compatible-mode/v1/embeddings
          api-key: ${CHATCHAT_EMBEDDING_ENCRYPTED_API_KEY:${CHATCHAT_EMBEDDING_API_KEY:}}
          model: text-embedding-v4
          dimension: 1024
          vector-field: mcpContentVector
          max-input-chars: 6000
          vector-candidate-limit: 50
          bm25-weight: 0.55
          vector-weight: 0.45
    cache:
      enabled: true
      path: ./data/mcp-cache-rocksdb
      create-if-missing: true
      cleanup-interval-ms: 60000
      cleanup-batch-size: 500
    server:
      name: chatchat-langchain4j-mcp-server
      version: 1.0.0-SNAPSHOT
      endpoint: /mcp
      expose-agent-compatible-only: true
      excluded-tool-names: []
      instructions: "ChatChat standalone MCP server exposing LangChain4j-compatible tools."
      output:
        # sql_metadata_search text summary character limit. -1 means unlimited.
        sql-metadata-search-summary-max-chars: 6000
        # sql_metadata_search text summary field count limit. -1 means unlimited.
        sql-metadata-search-summary-max-columns: 30
      document-search:
        api-base-url: http://localhost:8080
        endpoint-path: /api/v1/search/document-search
        timeout-ms: 60000
        auth:
          enabled: true
          login-path: /api/v1/enterprise/auth/login
          username: chatchat_mcp_internal
          encrypted-password:
          password: 
          bearer-token: 
      concurrency:
        # Enables global/tool/user/agent concurrency guards for MCP tool calls.
        enabled: true
        # Global limit shared by all MCP tool calls.
        global:
          max-concurrency: 64
          queue-size: 128
          queue-timeout-seconds: 5
          timeout-seconds: 30
          runtime-level: global
        # Default limit used when no runtime-level or tool-specific limit matches.
        defaults:
          max-concurrency: 8
          queue-size: 64
          queue-timeout-seconds: 5
          timeout-seconds: 30
          runtime-level: tool
          max-output-chars: 200000
          retry-attempts: 0
          failure-threshold: 5
          circuit-open-seconds: 30
        # Per-user limit when a request carries user identity fields.
        user:
          max-concurrency: 8
          queue-size: 64
          queue-timeout-seconds: 5
          timeout-seconds: 30
          runtime-level: user
        # Per-agent limit when a request carries agent identity fields.
        agent:
          max-concurrency: 4
          queue-size: 32
          queue-timeout-seconds: 5
          timeout-seconds: 30
          runtime-level: agent
        # Runtime-level defaults for tool families.
        runtime-levels:
          ssh:
            max-concurrency: 2
            queue-size: 32
            queue-timeout-seconds: 10
            timeout-seconds: 30
            runtime-level: ssh
          sql:
            max-concurrency: 5
            queue-size: 64
            queue-timeout-seconds: 10
            timeout-seconds: 30
            runtime-level: sql
          http:
            max-concurrency: 30
            queue-size: 256
            queue-timeout-seconds: 5
            timeout-seconds: 30
            runtime-level: http
          notification:
            max-concurrency: 10
            queue-size: 128
            queue-timeout-seconds: 5
            timeout-seconds: 30
            runtime-level: notification
        # Tool-specific overrides. 0 means wait for completion; users can cancel long-running web calls manually.
        tools:
          document_search:
            max-concurrency: 8
            queue-size: 64
            queue-timeout-seconds: 5
            timeout-seconds: 300
            runtime-level: tool
          web_search:
            max-concurrency: 2
            queue-size: 32
            queue-timeout-seconds: 0
            timeout-seconds: 0
            runtime-level: http
  tools:
    livedata:
      # Enables the admin page to list and manually register LiveData APIs. Startup auto-sync is disabled.
      enabled: false
      jdbc-url: 
      username: 
      password: 
      driver-class: com.mysql.cj.jdbc.Driver
      table-name: ld_dataservice_api
      service-base-url: 
      service-path-template: /service/{serviceName}/call
      login-enabled: true
      login-path: /login
      login-id: 
      login-pwd: 
      login-timeout-ms: 10000
      session-ttl-seconds: 1800
      ams-token: 
      default-namespace: livedata
      tool-name-prefix: livedata_
      published-state: 0
      max-apis: 1000
      timeout-ms: 20000
      cache-enabled: false
      cache-ttl-seconds: 300
      overwrite-existing: false
      include-unpublished-as-disabled: false
      expose-ams-token-parameter: false
    calculator:
      # Safe local arithmetic tool.
      risk-level: low
      operation-type: read
      timeout-ms: 5000
      confirmation:
        default: auto_execute
      parameter-policy:
        expression: auto_execute
    document-search:
      # Retrieves documents from the ChatChat runtime/API service.
      enabled: true
      # Runtime/API retrieval service address. Set this when MCP Server and Runtime are deployed separately.
      api-base-url: http://localhost:8080
      search-path: /api/v1/search/document-search
      detail-path-template: /api/v1/search/documents/{docId}
      timeout-ms: 300000
      default-limit: 5
      max-limit: 20
      auth:
        # Login-based auth is used when bearer-token is empty.
        enabled: true
        login-path: /api/v1/enterprise/auth/login
        username: chatchat_mcp_internal
        encrypted-password:
        password: 
        bearer-token: ""
      risk-level: medium
      confirmation:
        default: ask_before_execute
    database-query:
      # Read-only SQL query tool for configured external databases.
      enabled: true
      risk-level: high
      operation-type: read
      user-visible: false
      agent-compatible: false
      confirmation:
        default: ask_before_execute
      parameter-policy:
        # JDBC URL and password require confirmation because they may reveal sensitive infrastructure.
        jdbc-url: ask_before_execute
        password: ask_before_execute
      default-max-rows: 50
      max-rows: 500
      workflow:
        max-parallelism: ${CHATCHAT_DATABASE_QUERY_WORKFLOW_MAX_PARALLELISM:4}
      # Statement timeout for database calls.
      query-timeout-seconds: 15
      # Extra JDBC drivers can be placed here in release packages.
      driver-lib-path: ./lib/drivers
    file-system:
      # Local file inspection tool. Keep confirmation enabled because paths may expose sensitive files.
      risk-level: high
      operation-type: read
      timeout-ms: 10000
      confirmation:
        default: ask_before_execute
      parameter-policy:
        path: ask_before_execute

logging:
  charset:
    console: UTF-8
    file: UTF-8
  file:
    name: ./logs/chatchat-mcp-server.log
  level:
    root: INFO
    com.chatchat: INFO
    io.modelcontextprotocol: INFO
    org.springframework.boot.autoconfigure: WARN
    org.springframework.boot.autoconfigure.logging.ConditionEvaluationReportLogger: WARN
    org.hibernate: WARN
    org.hibernate.SQL: WARN
    org.hibernate.orm.jdbc.bind: WARN
    org.hibernate.type.descriptor.sql.BasicBinder: WARN
  logback:
    rollingpolicy:
      max-file-size: 100MB
      max-history: 30
      total-size-cap: 3GB
  pattern:
    console: "%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"
