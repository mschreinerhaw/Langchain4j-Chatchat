<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 https://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>release</id>
    <formats>
        <format>zip</format>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>${project.artifactId}-${project.version}</baseDirectory>

    <files>
        <file>
            <source>${project.build.directory}/${project.build.finalName}.jar</source>
            <outputDirectory>/lib</outputDirectory>
            <destName>chatchat-runtime-news.jar</destName>
        </file>
        <file>
            <source>${project.basedir}/src/main/distribution/README.md</source>
            <outputDirectory>/</outputDirectory>
            <destName>README.md</destName>
        </file>
    </files>

    <fileSets>
        <fileSet>
            <directory>${project.basedir}/src/main/scripts</directory>
            <outputDirectory>/bin</outputDirectory>
            <fileMode>0755</fileMode>
            <includes><include>*.sh</include></includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/scripts</directory>
            <outputDirectory>/bin</outputDirectory>
            <fileMode>0644</fileMode>
            <includes><include>*.ps1</include><include>*.bat</include></includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/distribution/config</directory>
            <outputDirectory>/config</outputDirectory>
            <includes><include>**/*</include></includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/doc</directory>
            <outputDirectory>/doc</outputDirectory>
            <includes><include>*.md</include></includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../database/init/mysql</directory>
            <outputDirectory>/config/sql/mysql</outputDirectory>
            <includes><include>chatchat-runtime-news.sql</include></includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../database/init/h2</directory>
            <outputDirectory>/config/sql/h2</outputDirectory>
            <includes><include>chatchat-runtime-news.sql</include></includes>
        </fileSet>
        <fileSet><directory>${project.basedir}/src/main/distribution/data</directory><outputDirectory>/data</outputDirectory><includes><include>**/*</include></includes></fileSet>
        <fileSet><directory>${project.basedir}/src/main/distribution/lib</directory><outputDirectory>/lib</outputDirectory><includes><include>**/*</include></includes></fileSet>
        <fileSet><directory>${project.basedir}/src/main/distribution/logs</directory><outputDirectory>/logs</outputDirectory><includes><include>**/*</include></includes></fileSet>
        <fileSet><directory>${project.basedir}/src/main/distribution/run</directory><outputDirectory>/run</outputDirectory><includes><include>**/*</include></includes></fileSet>
    </fileSets>
</assembly>
